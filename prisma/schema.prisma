generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id            String         @id @default(cuid())
  trackingCode  String         @unique
  status        String         @default("pending")
  // FIXME: status should be an enum but SQLite doesn't support enums well
  // Some places use uppercase, some lowercase — need to standardize
  
  customerId    String
  customer      Customer       @relation(fields: [customerId], references: [id])
  
  courierId     String?
  courier       Courier?       @relation(fields: [courierId], references: [id])
  
  pickupAddress    String
  deliveryAddress  String
  pickupLatitude   Float?
  pickupLongitude  Float?
  deliveryLatitude Float?
  deliveryLongitude Float?
  
  weight        Float?
  notes         String?
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  delivery      Delivery?
  route         Route?
  notifications Notification[]
  statusHistory StatusHistory[]
  
  @@index([status])
  @@index([customerId])
  @@index([courierId])
}

model Customer {
  id            String       @id @default(cuid())
  name          String
  email         String
  phone         String
  address       String
  city          String
  postalCode    String
  latitude      Float?
  longitude     Float?
  
  orders        Order[]
  notifications Notification[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Courier {
  id            String       @id @default(cuid())
  name          String
  email         String
  phone         String
  vehicle       String       @default("van")
  // available, on_delivery, offline
  status        String       @default("available")
  
  company       String?
  city          String?
  latitude      Float?
  longitude     Float?
  
  orders        Order[]
  deliveries   Delivery[]
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@index([status])
}

model Delivery {
  id            String       @id @default(cuid())
  orderId       String       @unique
  order         Order         @relation(fields: [orderId], references: [id])
  
  courierId     String
  courier       Courier       @relation(fields: [courierId], references: [id])
  
  status        String        @default("pending")
  // TODO: This duplicates the order status — should probably be removed
  
  pickupTime    DateTime?
  deliveryTime  DateTime?
  estimatedTime DateTime?
  actualTime    DateTime?
  
  notes         String?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@index([courierId])
  @@index([status])
}

model Route {
  id            String       @id @default(cuid())
  orderId       String       @unique
  order         Order         @relation(fields: [orderId], references: [id])
  
  courierId     String?
  // TODO: Route optimization was never implemented
  // See routeOptimizer.ts for the dead code
  
  waypoints     String       @default("[]")
  // JSON string of {lat, lng, address}[]
  // FIXME: Should use Json type but SQLite doesn't support it well
  
  distance      Float?       // in km
  estimatedDuration Float?   // in minutes
  actualDuration  Float?
  
  status        String       @default("planned")
  // planned, in_progress, completed
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Notification {
  id            String       @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  
  customerId    String
  customer      Customer       @relation(fields: [customerId], references: [id])
  
  type          String
  // email, sms, push
  message       String
  status        String        @default("pending")
  // pending, sent, failed
  
  sentAt        DateTime?
  
  createdAt     DateTime     @default(now())
  
  @@index([orderId])
  @@index([customerId])
}

model StatusHistory {
  id            String       @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id])
  
  status        String
  previousStatus String?
  
  changedBy     String?
  note          String?
  
  createdAt     DateTime     @default(now())
  
  @@index([orderId])
}
